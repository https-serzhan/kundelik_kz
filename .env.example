# ===== Google Gemini (ИИ-функции) =====
# Получить ключ: https://aistudio.google.com/apikey
# Без ключа приложение работает, но ИИ-разделы показывают демо-ответы.
GEMINI_API_KEY=

# ===== Админ-аккаунт (необязательно — по умолчанию admin@kundelik.local / admin12345) =====
# ADMIN_EMAIL=admin@kundelik.local
# ADMIN_PASSWORD=admin12345
# ADMIN_NAME=Администратор

# ===== Сервер (необязательно) =====
# PORT=3000
# NODE_ENV=development
# SESSION_SECRET=          # обязателен в production

# ===== Хранилище (необязательно — по умолчанию в корне проекта) =====
# KUNDELIK_DB=kundelik.db
# KUNDELIK_UPLOADS=uploads
